{
  "manifest_version": 3,
  "name": "VisionClip - Image OCR to Clipboard",
  "version": "0.1.0",
  "description": "Right-click an image, extract text with a multimodal model, and copy the result to the macOS clipboard.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "nativeMessaging",
    "storage",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "VisionClip - Image OCR to Clipboard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "start-region-ocr": {
      "suggested_key": {
        "default": "Alt+Shift+O"
      },
      "description": "範囲OCRを開始"
    }
  },
  "options_page": "options.html"
}
